	</ValidBetween>
	<!-- Note: Abbreviation of the STOP PLACE. -->
	<!-- Usage: mandatory -->
	<alternativeTexts>
		<!-- Note: Variant for de is always required. Further languages fr, it, en only necessary if different from de. -->
		<!-- Usage: mandatory -->
		<AlternativeText attributeName="Text">
			<!-- Usage: mandatory -->
			<Text lang="de">Interlaken West</Text>
		</AlternativeText>
	</alternativeTexts>
	<!-- Note: KEY LIST with the KEY VALUEs related to the STOP PLACE. SKI use KeyValues: one for the Didok number one for the SLOID For delivery to SKI only one Value is necessary. -->
	<!-- Usage: mandatory -->
	<keyList>
		<!-- Usage: mandatory -->
		<KeyValue>
			<Key>DIDOK</Key>
			<Value>8507493</Value>
		</KeyValue>
		<KeyValue>
			<Key>SLOID</Key>
			<Value>ch:1:sloid:71310</Value>
		</KeyValue>
	</keyList>
	<!-- Usage: mandatory -->
	<Extensions>
		<!-- Usage: mandatory -->
		<HafasPriority>
			<!-- Usage: mandatory -->
			<Value>4</Value>
		</HafasPriority>
		<!-- Usage: expected -->
		<HafasKMInfo>
			<!-- Usage: mandatory -->
			<Value>14</Value>
		</HafasKMInfo>
	</Extensions>
	<!-- Usage: mandatory -->
	<Name>Interlaken West</Name>
	<!-- Note: Is used to transmit the abbreviation of the StopPlace. There is not one abbreviation for all StopPlaces-->
	<!-- Usage: expected -->
	<ShortName lang="de">8507493</ShortName>
	<!-- Note: Field **must be filled**. In Switzerland it is the **DiDok** number. -->
	<!-- Usage: mandatory -->
	<PrivateCode>8507493</PrivateCode>
	<Centroid>
		<Location>
			<Longitude>7.851453</Longitude>
			<Latitude>46.682627</Latitude>
			<Altitude>563</Altitude>
		</Location>
	</Centroid>
	<!-- Note: We will also use these for synonyms. From INFO+ the synonyms are used on the StopPlace.-->
	<!-- Usage: expected -->
	<alternativeNames>
		<!-- Note: **Use NameType alias, TypeOfName official.** -->
		<!-- Usage: expected -->
		<AlternativeName id="ch:1:AlternativeName:StopPlace:8507493_4" version="any">
			<NameType>alias</NameType>
			<TypeOfName>offical</TypeOfName>
			<Name lang="de">Interlaken West</Name>
