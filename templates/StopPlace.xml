									<!-- ch-see -->
									<Text>CHR</Text>
								</AlternativeText>
							</alternativeTexts>
							<keyList>
								<!-- ch-usage: mandatory -->
								<!-- ch-note: KEY LIST with the KEY VALUEs related to the STOP PLACE.\
								SKI use KeyValues:\
								- one for the Didok number
								- one for the SLOID
								For delivery to SKI only one Value is necessary.
								-->
								<KeyValue>
									<!-- ch-usage: mandatory -->
									<Key>
										<!-- ch-usage: mandatory -->
										<!-- ch-note: DIDOK number has to be provided -->
										DIDOK
									</Key>
									<Value>
										<!-- ch-usage: mandatory -->
										7000
									</Value>
								</KeyValue>
								<KeyValue>
									<Key>
										<!-- ch-usage: mandatory -->
										<!-- ch-note: SLOID has to be provided **TODO** really mandatory, stations outside CH?-->
										SLOID
									</Key>
									<Value>
										<!-- ch-usage: mandatory -->
										ch:1:sloid:7000
									</Value>
								</KeyValue>
							</keyList
							<Extensions>
								<!-- ch-usage: optional -->
								<!-- ch-note: Extensions of the STOP PLACE:
								- HafasPriority
								- HafasKMInfo
								-->
								<HafasPriority>
									<!-- ch-usage: optional -->
									<!-- ch-note: (**TODO** Replace by Weighting ?) Interchange Priority, when several alternative interchange possibilities exist. -->
            						<Value>
										<!-- ch-usage: mandatory -->
										<!-- ch-note: **TODO** Allowed values... -->
										4
									</Value>
        						</HafasPriority>
								<HafasKMInfo>
									<!-- ch-usage: optional -->
									<!-- ch-note: **TODO** ...Value for Interchange points. -->
            						<Value>
										<!-- ch-usage: mandatory -->
										<!-- ch-note: km -->
										1000
									</Value>
        						</HafasKMInfo>
							</Extensions>
							<Name><!-- ch-usage: mandatory -->Bern</Name>
							<ShortName><!-- ch-note: Used to transmit the abbreviation of the StopPlace. There is not one abbreviation for all StopPlaces-->BE</ShortName>
							<privateCodes>
								<!-- ch-usage: mandatory -->
								<PrivateCode>
									<!-- ch-usage: mandatory -->
									<!-- ch-note: In Switzerland to be filled with the DiDok number. Replaces single PublicCode from NeTEx 1.0 -->
									7000
								</PrivateCode>
							</privateCodes>
							<PrivateCode>
								<!-- ch-usage: forbidden -->
								<!-- ch-note: Replaced by PublicCode nested within publicCodes, see above. -->
							</PrivateCode>
							<Centroid>
								<!-- ch-usage: mandatory -->
								<!-- ch-note: Global or national location of STOP PLACE.-->
								<Name><!-- ch-usage: optional --></Name>
								<Location>
									<!-- ch-usage: mandatory -->
									<!-- ch-note: Note concerning coordinates:
- The main coordinates are given as **WSG84**.
- The Swiss coordinates are added as well, when available
- INFO+ will not use the data from the import. Always the DIDOK master data will be used for all Swiss coordinates. INFO+ will use the data of foreign places.
									-->
									<Longitude><!-- ch-usage: mandatory -->7.43913088992</Longitude>
									<Latitude><!-- ch-usage: mandatory -->46.94883228914</Latitude>
									<Altitude><!-- ch-usage: optional -->540.2</Altitude>
								</Location>
							</Centroid>
							<Url>
								<!-- ch-usage: forbidden -->
							</Url>
							<ShortName>
								<!-- ch-usage: optional -->
								<!-- ch-note: Used for the abbreviation of the name if an abbreviation exists / is necessary -->
							<alternativeNames>
								<!-- ch-usage: optional -->
								<!-- ch-note: **TODO** Alternative names for SITE ELEMENT.\
								We will also use these for synonyms. From INFO+ the synonyms are used on the Stop-Place.
								-->
								<AlternativeName id="ch:1:sloid:7000:it" version="1">
									<!-- ch-see -->
									<Name lang="it">Berna</Name>
								</AlternativeName>
							</alternativeNames>
							<StopPlaceType>
								<!-- ch-usage: optional -->
								railStation
							</StopPlaceType>
							<quays>
